# Copy this file to `.env` and adjust values for your benchmark run.

# Benchmark targets
BENCH_REDIS_OFFICIAL_HOST=redis-official
BENCH_REDIS_OFFICIAL_PORT=6379
BENCH_MINI_REDIS_HOST=mini-redis
BENCH_MINI_REDIS_PORT=6379
BENCH_MONGO_HOST=mongodb
BENCH_MONGO_PORT=27017

# Benchmark workload
BENCH_ITERATIONS=100000
BENCH_WARMUP=1000
BENCH_PIPELINE_BATCH=100
BENCH_TTL_SECONDS=60
BENCH_VALUE_SIZE=256
BENCH_CACHE_KEY_COUNT=1000
BENCH_SESSION_COUNT=1000
BENCH_RATE_USER_COUNT=500
BENCH_QUEUE_COUNT=16
BENCH_LEADERBOARD_PLAYERS=5000
BENCH_CACHE_HIT_KEYS=1000
BENCH_STARTUP_DELAY_SECONDS=3
BENCH_SOCKET_TIMEOUT_SECONDS=5
BENCH_RANDOM_SEED=42

# Published ports on the host machine
REDIS_OFFICIAL_HOST_PORT=6379
MINI_REDIS_HOST_PORT=6380
MONGO_HOST_PORT=27017

# Official Redis options
REDIS_APPENDONLY=no
REDIS_MAXMEMORY=0
REDIS_MAXMEMORY_POLICY=noeviction

# mini-redis server options
MINI_REDIS_SERVER_PORT=6379
MINI_REDIS_READ_CHUNK=4096
MINI_REDIS_EXPIRY_LOOP_INTERVAL_MS=100
MINI_REDIS_EXPIRY_SAMPLE_SIZE=20
MINI_REDIS_EXPIRY_MAX_PASSES=4
MINI_REDIS_MAXMEMORY=64mb
MINI_REDIS_MAXMEMORY_POLICY=allkeys-lru
MINI_REDIS_APPENDONLY=yes
MINI_REDIS_AOF_FILE=data/appendonly.aof
MINI_REDIS_AOF_FSYNC=everysec
MINI_REDIS_RDB_ENABLED=yes
MINI_REDIS_RDB_FILE=data/dump.rdb
MINI_REDIS_RDB_SAVE_INTERVAL_SECONDS=30
MINI_REDIS_CLIENT_IDLE_TIMEOUT_SECONDS=30
MINI_REDIS_WRITE_DRAIN_TIMEOUT_SECONDS=5
MINI_REDIS_MAX_INPUT_BUFFER_BYTES=1048576
MINI_REDIS_MAX_OUTPUT_BUFFER_BYTES=262144
MINI_REDIS_MAX_COMMANDS_PER_TICK=128
MINI_REDIS_LOG_LEVEL=INFO
